
/**
 * Bishops Hull Hub Security Rules
 *
 * Core Philosophy:
 * Public data (initiatives, gallery, and page content) is globally readable.
 * Booking enquiries are public for submission (create) but managed only by admins.
 * The Security Team can perform a one-time "Review" action via a public tokenized path.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == 'bishopshullhub@gmail.com'
      );
    }

    function isExistingAdmin() {
      return isAdmin() && resource != null;
    }

    function matchesPathId(id) {
      return request.resource.data.id == id;
    }

    function idIsImmutable() {
      return request.resource.data.id == resource.data.id;
    }

    // --- Collection Rules ---

    match /booking_enquiries/{enquiryId} {
      // Admins have full access
      allow get, list: if isAdmin();
      
      // Public needs to GET the specific enquiry to show the review summary
      allow get: if true;

      // Submission
      allow create: if isSignedIn() && matchesPathId(enquiryId);
      
      // Update: Admin can update anything. 
      // Security Team (public) can ONLY update the 'status' to 'Reviewed'.
      allow update: if (isExistingAdmin() && idIsImmutable()) || (
        request.resource.data.status == 'Reviewed' && 
        request.resource.data.id == resource.data.id &&
        request.resource.data.name == resource.data.name // Ensure other data stays consistent
      );

      allow delete: if isExistingAdmin();
    }

    match /community_initiatives/{initiativeId} {
      allow read: if true;
      allow create: if isAdmin() && matchesPathId(initiativeId);
      allow update: if isExistingAdmin() && idIsImmutable();
      allow delete: if isExistingAdmin();
    }

    match /gallery_images/{imageId} {
      allow read: if true;
      allow create: if isAdmin() && matchesPathId(imageId);
      allow update: if isExistingAdmin() && idIsImmutable();
      allow delete: if isExistingAdmin();
    }

    match /page_contents/{contentId} {
      allow read: if true;
      allow create: if isAdmin() && matchesPathId(contentId);
      allow update: if isExistingAdmin() && idIsImmutable();
      allow delete: if isExistingAdmin();
    }

    match /faqs/{faqId} {
      allow read: if true;
      allow create: if isAdmin() && matchesPathId(faqId);
      allow update: if isExistingAdmin() && idIsImmutable();
      allow delete: if isExistingAdmin();
    }

    match /security_team/{contactId} {
      allow read, write: if isAdmin();
    }

    match /admins/{adminId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update, delete: if false;
    }
  }
}
