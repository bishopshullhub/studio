/**
 * Bishops Hull Hub Security Rules
 *
 * Core Philosophy:
 * This ruleset implements a role-based administrative model designed for a community hub. 
 * Public data (schedules, initiatives, gallery, and page content) is globally readable to 
 * ensure the website remains accessible to all visitors. Data modification is strictly 
 * reserved for users whose UIDs are present in the top-level 'admins' collection.
 *
 * Data Structure:
 * The database is organized into flat, top-level collections for primary entities:
 * - /weekly_schedules: Publicly viewable activity timetables.
 * - /community_initiatives: Publicly viewable community projects.
 * - /gallery_images: Publicly viewable image metadata.
 * - /page_contents: Publicly viewable static website content.
 * - /booking_enquiries: Private submissions from users, readable only by admins.
 * - /admins: A registry of UIDs that grant administrative access.
 *
 * Key Security Decisions:
 * - Administrative Access: Handled via the 'admins' collection. This allows for high-performance 
 *   permission checks using the exists() function, avoiding complex custom claims.
 * - Public Submissions: Any authenticated user (including anonymous) can submit a 
 *   booking enquiry, but only admins can view or manage them.
 * - Relational Integrity: On creation of any document, the internal 'id' field must 
 *   match the Firestore Document ID to ensure data consistency for client-side queries.
 *
 * Denormalization for Authorization:
 * Because administrative privileges are centralized in the /admins collection, 
 * no data denormalization is required on the entity documents themselves. This 
 * maintains a clean schema while ensuring robust, centralized access control.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    /** @description Checks if the user is authenticated (including anonymous). */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the user's UID exists in the admin registry. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    /** @description Verifies administrative status and that the document exists for modifications. */
    function isExistingAdmin() {
      return isAdmin() && resource != null;
    }

    /** @description Enforces that the internal ID field matches the document path ID. */
    function matchesPathId(id) {
      return request.resource.data.id == id;
    }

    /** @description Ensures the 'id' field remains unchanged during updates. */
    function idIsImmutable() {
      return request.resource.data.id == resource.data.id;
    }

    // --- Collection Rules ---

    /**
     * @description Publicly readable activity schedules; editable only by admins.
     * @path /weekly_schedules/{scheduleId}
     * @allow get, list: if true; (Public access)
     * @allow create: if isAdmin() && matchesPathId(scheduleId);
     * @deny update: if !isAdmin(); (Only admins can change schedules)
     * @principle Role-based administrative writes with public read access.
     */
    match /weekly_schedules/{scheduleId} {
      allow get, list: if true;
      allow create: if isAdmin() && matchesPathId(scheduleId);
      allow update: if isExistingAdmin() && idIsImmutable();
      allow delete: if isExistingAdmin();
    }

    /**
     * @description Secure collection for booking enquiries. Submission is public; management is admin-only.
     * @path /booking_enquiries/{enquiryId}
     * @allow create: if isSignedIn() && matchesPathId(enquiryId); (Anonymous/Auth submission)
     * @allow get, list: if isAdmin(); (Admin-only review)
     * @deny get: if !isAdmin(); (Users cannot see their own enquiries after submission for security)
     * @principle Restricted read access with authorized document creation.
     */
    match /booking_enquiries/{enquiryId} {
      allow get, list: if isAdmin();
      allow create: if isSignedIn() && matchesPathId(enquiryId);
      allow update: if isExistingAdmin() && idIsImmutable();
      allow delete: if isExistingAdmin();
    }

    /**
     * @description Publicly readable community initiatives and projects.
     * @path /community_initiatives/{initiativeId}
     * @allow get, list: if true;
     * @allow create: if isAdmin() && matchesPathId(initiativeId);
     * @deny delete: if !isAdmin();
     * @principle Enforces administrative control over public-facing content.
     */
    match /community_initiatives/{initiativeId} {
      allow get, list: if true;
      allow create: if isAdmin() && matchesPathId(initiativeId);
      allow update: if isExistingAdmin() && idIsImmutable();
      allow delete: if isExistingAdmin();
    }

    /**
     * @description Metadata for images displayed in the site galleries.
     * @path /gallery_images/{imageId}
     * @allow get, list: if true;
     * @allow create: if isAdmin() && matchesPathId(imageId);
     * @deny update: if request.resource.data.storagePath == null; (Hypothetical integrity check)
     * @principle Public gallery access with restricted administrative management.
     */
    match /gallery_images/{imageId} {
      allow get, list: if true;
      allow create: if isAdmin() && matchesPathId(imageId);
      allow update: if isExistingAdmin() && idIsImmutable();
      allow delete: if isExistingAdmin();
    }

    /**
     * @description Static page content (e.g., Privacy Policy, Hire Prices).
     * @path /page_contents/{contentId}
     * @allow get, list: if true;
     * @allow create: if isAdmin() && matchesPathId(contentId);
     * @deny create: if !isAdmin();
     * @principle Facilitates dynamic content management by administrators.
     */
    match /page_contents/{contentId} {
      allow get, list: if true;
      allow create: if isAdmin() && matchesPathId(contentId);
      allow update: if isExistingAdmin() && idIsImmutable();
      allow delete: if isExistingAdmin();
    }

    /**
     * @description The registry of administrative users.
     * @path /admins/{adminId}
     * @allow get: if isSignedIn(); (Users check if they are admins)
     * @allow list: if isAdmin(); (Admins can see the admin list)
     * @deny create, update, delete: if true; (Admin management happens via manual console or Cloud Functions)
     * @principle Root-level security for the authorization source of truth.
     */
    match /admins/{adminId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update, delete: if false;
    }
  }
}