
{
  "entities": {
    "BookingEnquiry": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "BookingEnquiry",
      "type": "object",
      "description": "Stores information submitted through the 'Hire the Hub' booking enquiry form, used for administrative review and communication.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the BookingEnquiry entity."
        },
        "name": {
          "type": "string",
          "description": "The full name of the person submitting the enquiry."
        },
        "emailAddress": {
          "type": "string",
          "description": "The email address of the enquirer for follow-up communication.",
          "format": "email"
        },
        "phoneNumber": {
          "type": "string",
          "description": "The phone number of the enquirer."
        },
        "postalAddress": {
          "type": "string",
          "description": "The full postal address of the enquirer."
        },
        "postcode": {
          "type": "string",
          "description": "The postcode of the enquirer."
        },
        "preferredContact": {
          "type": "string",
          "description": "How the user prefers to be contacted (Email or Phone)."
        },
        "dateRequired": {
          "type": "string",
          "description": "The specific date requested for the booking.",
          "format": "date"
        },
        "startTime": {
          "type": "string",
          "description": "The requested start time for the booking in HH:MM format."
        },
        "endTime": {
          "type": "string",
          "description": "The requested end time for the booking in HH:MM format."
        },
        "typeOfEvent": {
          "type": "string",
          "description": "A description of the type of event or purpose of the booking."
        },
        "estimatedAttendance": {
          "type": "number",
          "description": "The estimated number of attendees for the event."
        },
        "additionalRequirements": {
          "type": "string",
          "description": "Any additional requirements or special requests from the enquirer."
        },
        "submissionDateTime": {
          "type": "string",
          "description": "The timestamp when the booking enquiry was submitted.",
          "format": "date-time"
        },
        "status": {
          "type": "string",
          "description": "The current processing status of the booking enquiry.",
          "enum": ["Pending", "Reviewed", "Confirmed", "Rejected"]
        }
      },
      "required": [
        "id",
        "name",
        "emailAddress",
        "dateRequired",
        "startTime",
        "endTime",
        "typeOfEvent",
        "submissionDateTime"
      ]
    },
    "CommunityInitiative": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "CommunityInitiative",
      "type": "object",
      "description": "Defines a community project or initiative, including its details, call-to-action, and links.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the CommunityInitiative entity."
        },
        "title": {
          "type": "string",
          "description": "The main title of the community initiative."
        },
        "slug": {
          "type": "string",
          "description": "A URL-friendly identifier for the initiative."
        },
        "description": {
          "type": "string",
          "description": "The full explanatory text detailing the purpose."
        },
        "callToActionText": {
          "type": "string",
          "description": "The text displayed on a call-to-action button."
        },
        "callToActionLink": {
          "type": "string",
          "description": "The URL or internal path associated with the call-to-action.",
          "format": "uri"
        },
        "displayOrder": {
          "type": "number",
          "description": "Sorting order."
        }
      },
      "required": [
        "id",
        "title",
        "slug",
        "description",
        "callToActionText",
        "callToActionLink"
      ]
    },
    "GalleryImage": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "GalleryImage",
      "type": "object",
      "description": "Stores metadata for images used in galleries.",
      "properties": {
        "id": {
          "type": "string"
        },
        "storagePath": {
          "type": "string"
        },
        "altText": {
          "type": "string"
        },
        "caption": {
          "type": "string"
        },
        "category": {
          "type": "string"
        },
        "uploadDate": {
          "type": "string",
          "format": "date-time"
        },
        "displayOrder": {
          "type": "number"
        }
      },
      "required": [
        "id",
        "storagePath",
        "altText",
        "category",
        "uploadDate"
      ]
    },
    "PageContent": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "PageContent",
      "type": "object",
      "description": "Manages static content for various pages or sections of the website.",
      "properties": {
        "id": {
          "type": "string"
        },
        "slug": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "content": {
          "type": "string"
        },
        "lastUpdated": {
          "type": "string",
          "format": "date-time"
        },
        "category": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "slug",
        "title",
        "content",
        "lastUpdated"
      ]
    },
    "SecurityContact": {
      "title": "SecurityContact",
      "type": "object",
      "description": "A contact person in the security team mailing list.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "addedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "email", "addedAt"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/booking_enquiries/{enquiryId}",
        "definition": {
          "entityName": "BookingEnquiry",
          "schema": {
            "$ref": "#/backend/entities/BookingEnquiry"
          },
          "description": "Holds booking enquiry submissions."
        }
      },
      {
        "path": "/community_initiatives/{initiativeId}",
        "definition": {
          "entityName": "CommunityInitiative",
          "schema": {
            "$ref": "#/backend/entities/CommunityInitiative"
          },
          "description": "Contains details for various community projects."
        }
      },
      {
        "path": "/gallery_images/{imageId}",
        "definition": {
          "entityName": "GalleryImage",
          "schema": {
            "$ref": "#/backend/entities/GalleryImage"
          },
          "description": "Stores metadata for images displayed in galleries."
        }
      },
      {
        "path": "/page_contents/{contentId}",
        "definition": {
          "entityName": "PageContent",
          "schema": {
            "$ref": "#/backend/entities/PageContent"
          },
          "description": "Manages static content for various pages."
        }
      },
      {
        "path": "/security_team/{contactId}",
        "definition": {
          "entityName": "SecurityContact",
          "schema": {
            "$ref": "#/backend/entities/SecurityContact"
          },
          "description": "Mailing list for the security team."
        }
      },
      {
        "path": "/admins/{adminId}",
        "definition": {
          "entityName": "admin",
          "schema": {
            "title": "User",
            "type": "object",
            "properties": {
              "uid": { "type": "string" }
            }
          },
          "description": "Admin registry."
        }
      }
    ]
  }
}
